# =============================================================================
# OUC Tasks — environment variable template
# =============================================================================
# Copy this file to .env.local and fill in real values from your Supabase
# project's API settings page. .env.local is gitignored — never commit it.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Anything without that prefix is server-side only.
# =============================================================================

# ---- Supabase (required) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Service role key — bypasses RLS. Server-side only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ---- Transactional email (required for notifications) ----
# Pick one provider — Resend recommended for simplicity.
RESEND_API_KEY=re_YOUR_KEY
EMAIL_FROM="OUC Tasks <noreply@oucsda.org>"

# ---- App config ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="OUC Infrastructure Tasks"

# ---- Supabase Storage ----
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=receipts
